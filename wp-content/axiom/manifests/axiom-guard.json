{
    "id": "axiom-guard",
    "name": "axiom-guard",
    "manifest_version": "1.0",
    "isolation": "namespace",
    "permissions": {
        "db": {
            "read": [],
            "write": [],
            "delete": [],
            "alter": []
        },
        "filesystem": [],
        "network": {
            "outbound": []
        },
        "wp": {
            "hooks": {
                "read_only": [],
                "write": []
            },
            "options": {
                "read": [],
                "write": []
            },
            "users": {
                "read": []
            }
        },
        "system": []
    },
    "resource_limits": {
        "cpu_ms": 500,
        "memory_mb": 64
    }
}